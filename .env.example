# RepoGenius AI — Environment Configuration
# Copy this to .env and fill in your values

# Core Infrastructure
DATABASE_URL=sqlite+aiosqlite:///./repogenius.db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=dev-secret-key-change-in-production

# AI Provider
OLLAMA_BASE_URL=http://localhost:11434
AI_PROVIDER_ORDER=["ollama"]

# Orchestrator Settings
ORCHESTRATOR_CONCURRENCY=10
AGENT_TIMEOUT_SECONDS=60

# Feature Flags
ENABLE_KG=false
ENABLE_OPTIMIZATION=true
ENABLE_SECURITY=true
ENABLE_CODE_QUALITY=true
ENABLE_ARCHITECTURE=true
ENABLE_DEPENDENCY=true
ENABLE_TECHNICAL_DEBT=true

# Workspace (where repos are cloned)
WORKSPACE_DIR=./workspace
