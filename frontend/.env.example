# Backend API URL — set this in production (Vercel) to your Render backend URL
# Example: https://repogenius-api.onrender.com
#
# For local development: leave empty (Vite proxy handles routing to backend)
# For Vercel deployment: set as environment variable in Vercel dashboard
#   Settings → Environment Variables → VITE_API_URL = https://repogenius-api.onrender.com
VITE_API_URL=
